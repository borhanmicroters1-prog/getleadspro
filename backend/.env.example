# App settings
ENVIRONMENT=development
PORT=8000
SUPER_ADMIN_EMAIL=admin@getleads.com
# Secret token to authorize HTTP trigger cron jobs (e.g. Vercel Cron/Google Cloud Scheduler)
CRON_SECRET=super-secret-cron-key-for-local-testing

# Database settings
# Example: postgresql+asyncpg://postgres:password@localhost:5432/postgres
# Or Supabase direct connection pooler: postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/getleads

# Supabase Auth settings
# Get this from Supabase Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# AI API Keys
# Optional: Add keys to activate live AI generation
ANTHROPIC_API_KEY=your-claude-api-key-here
OPENAI_API_KEY=your-chatgpt-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# SSLCommerz Configuration (Bangladesh Payments)
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id-here
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password-here
SSLCOMMERZ_IS_SANDBOX=True

# Application URLs
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://your-backend-domain.render.com
